{
  "name": "omnis-cli",
  "version": "1.0.0",
  "description": "Omnis RegOps CLI — ships signed test evidence to the Omnis platform.",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "omnis-run": "./index.ts"
  },
  "scripts": {
    "start": "bun run index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run build:win && bun run build:mac && bun run build:linux",
    "build:win": "bun build --compile --target=bun-windows-x64 --outfile=dist/omnis-run-win.exe ./index.ts",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 --outfile=dist/omnis-run-mac ./index.ts",
    "build:linux": "bun build --compile --target=bun-linux-x64 --outfile=dist/omnis-run-linux ./index.ts"
  },
  "dependencies": {
    "chalk": "5.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.4.5"
  }
}
