# ─────────────────────────────────────────────────────────────
# omnis-cli environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# Required: Your organisation's API key (generated in the Omnis dashboard).
# Must start with "omn_". The raw key is sent in the Authorization header
# and verified server-side via a salted SHA-256 hash — it is never stored.
OMNIS_API_KEY=omn_<your_key_here>

# Optional: Override the default Vercel ingest endpoint.
# Default: https://omnis-ui-ecru.vercel.app/api/ingest
# OMNIS_API_ENDPOINT=https://omnis-ui-ecru.vercel.app/api/ingest

# Optional: Override the developer identity recorded in the evidence log.
# By default, omnis-cli resolves the identity automatically via the
# priority chain: git config user.email → global git config → system user.
# Use this in CI/CD pipelines (GitHub Actions, Docker, Jenkins) where git
# user config may not be set or where you want a canonical service identity.
# Example: OMNIS_DEVELOPER_EMAIL=ci-pipeline@your-org.com
# OMNIS_DEVELOPER_EMAIL=
